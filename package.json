{
	"name": "@wolfstar/ring",
	"version": "1.0.0",
	"private": true,
	"description": "Private centralized management android for the WolfStar Network",
	"license": "Apache-2.0",
	"author": "WolfStar Project <contact@wolfstar.rocks>",
	"type": "module",
	"main": "dist/main.mjs",
	"imports": {
		"#api/*": "./dist/api/*.mjs",
		"#generated/prisma": "./dist/generated/prisma/client.mjs",
		"#lib/*": "./dist/lib/*.mjs"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "pnpm build --onSuccess \"pnpm start\"",
		"watch": "pnpm build --watch",
		"watch:start": "pnpm build --onSuccess \"pnpm start\"",
		"prisma:generate": "pnpm prisma generate",
		"clean": "node scripts/build/clean.mjs",
		"start": "node --enable-source-maps dist/main.mjs",
		"lint": "oxlint && oxfmt --check",
		"lint:fix": "oxlint --fix && oxfmt",
		"prepare": "test -f .husky/install.mjs && node .husky/install.mjs || true",
		"update:interactive": "taze"
	},
	"dependencies": {
		"@discordjs/builders": "^1.14.1",
		"@discordjs/collection": "^2.1.1",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@sapphire/result": "^2.8.0",
		"@sapphire/utilities": "^3.18.2",
		"@skyra/env-utilities": "^2.0.1",
		"@skyra/http-framework": "^2.2.1",
		"@skyra/http-framework-i18n": "^1.2.1",
		"@skyra/logger": "^2.0.4",
		"@skyra/shared-http-pieces": "^1.2.3",
		"@skyra/start-banner": "^2.0.2",
		"discord-api-types": "^0.38.47",
		"fastify": "^5.8.5",
		"gradient-string": "^3.0.0",
		"husky": "^9.1.7",
		"nano-staged": "^0.9.0",
		"tslib": "^2.8.1"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
		"@rollup/plugin-alias": "^6.0.0",
		"@sapphire/ts-config": "^5.0.3",
		"@types/gradient-string": "^1.1.6",
		"@types/node": "^24.12.2",
		"cz-conventional-changelog": "^3.3.0",
		"eslint": "^9.39.4",
		"eslint-plugin-regexp": "^3.1.0",
		"oxfmt": "^0.47.0",
		"oxlint": "^1.62.0",
		"prisma": "^7.8.0",
		"taze": "^19.11.0",
		"tsdown": "^0.21.10",
		"typescript": "~5.4.5"
	},
	"nano-staged": {
		"*.{js,ts,mjs,cjs}": [
			"pnpm oxlint --fix"
		],
		"*.{js,ts,mjs,cjs,json,yml,md}": [
			"pnpm oxfmt"
		]
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=10"
	},
	"packageManager": "pnpm@10.33.3"
}
