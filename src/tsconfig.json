{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "../dist",
		"rootDir": ".",
		"baseUrl": ".",
		"allowJs": true,
		"skipLibCheck": true,
		"paths": {
			"#lib/*": ["./lib/*"],
			"#api/*": ["./api/*"],
			"#generated/prisma": ["../generated/prisma/client"]
		}
	},
	"include": [".", "./**/*.json"],
	"exclude": ["./tsconfig.json"]
}
