# Discord Client Public Key
DISCORD_TOKEN=
DISCORD_PUBLIC_KEY=

REGISTRY_GUILD_ID=

# Sentry
SENTRY_DSN=

# The address and port on which to start the HTTP server
HTTP_ADDRESS=0.0.0.0
HTTP_PORT=3000

API_ADDRESS=0.0.0.0
API_PORT=3001

CLIENT_OWNERS='605162125027049472 '

# Token used by Staryl as INTERNAL_RING_TOKEN
INTERNAL_API_STARYL_TOKEN=
# Token used by WolfStar bot
INTERNAL_API_WOLFSTAR_TOKEN=

# Override values locally in src/.env.local (gitignored).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ring?schema=public"
